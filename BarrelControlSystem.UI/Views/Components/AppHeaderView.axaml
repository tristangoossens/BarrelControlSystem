<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="BarrelControlSystem.UI.Views.Components.AppHeaderView"
             x:Name="Root">
    <StackPanel Spacing="5">
        <!-- Logo or Icon and Title -->
        <StackPanel Orientation="Horizontal" Spacing="20">
            <!-- Conditional Logo/Icon -->
            <Panel Width="80" Height="80">
                <Image Source="/Assets/logo_80x80.png" IsVisible="{Binding IsHomePage, ElementName=Root}"/>
                <icons:MaterialIcon Kind="{Binding IconKind, ElementName=Root}" Width="64" Height="64" IsVisible="{Binding !IsHomePage, ElementName=Root}"/>
            </Panel>
            
            <StackPanel VerticalAlignment="Center" Spacing="5">
                <TextBlock Text="{Binding Title, ElementName=Root}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding Description, ElementName=Root}" 
                           FontSize="14" Foreground="#a0a0a0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Header Content (Action buttons etc) -->
        <ContentControl Content="{Binding HeaderContent, ElementName=Root}"/>
        
        <!-- Thicker Divider -->
        <Border Height="2" Background="#3c3c3c" HorizontalAlignment="Stretch" Margin="0,5, 0, 10"/>
    </StackPanel>
</UserControl>