<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BarrelControlSystem.UI.ViewModels.Dashboard"
             xmlns:views="clr-namespace:BarrelControlSystem.UI.Views.Components"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="BarrelControlSystem.UI.Views.Dashboard.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="30" Margin="0">
            <views:AppHeaderView IsHomePage="False" IconKind="ViewDashboard" Title="Dashboard" Description="Device monitoring" />
            <TextBlock Text="Dashboard Page" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
