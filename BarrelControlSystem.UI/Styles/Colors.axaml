<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="MainBackgroundBrush">#2b2b2b</SolidColorBrush>
    <SolidColorBrush x:Key="BorderBrush">#3c3c3c</SolidColorBrush>
    <SolidColorBrush x:Key="SubSectionBackgroundBrush">#333333</SolidColorBrush>
    <SolidColorBrush x:Key="ResetButtonBrush">#555555</SolidColorBrush>
    <SolidColorBrush x:Key="SaveButtonBrush">#2e7d32</SolidColorBrush>
    <SolidColorBrush x:Key="NavButtonBrush">#37474f</SolidColorBrush>
    <SolidColorBrush x:Key="MainPaneBackgroundBrush">#1e1e1e</SolidColorBrush>
    <SolidColorBrush x:Key="SecondaryTextBrush">#a0a0a0</SolidColorBrush>
    <SolidColorBrush x:Key="TertiaryTextBrush">#808080</SolidColorBrush>
    <SolidColorBrush x:Key="IconBrush">#555555</SolidColorBrush>
    <SolidColorBrush x:Key="IconLightBrush">#64b5f6</SolidColorBrush>
    <SolidColorBrush x:Key="IconHornBrush">#81c784</SolidColorBrush>
    <SolidColorBrush x:Key="IconToggledHornBrush">#fff176</SolidColorBrush>
    <SolidColorBrush x:Key="IconUnknownBrush">#ffb74d</SolidColorBrush>
</ResourceDictionary>